{
  "name": "@mdkit/core",
  "version": "0.1.0",
  "description": "Headless schema and helpers for the mdkit registry.",
  "license": "MIT",
  "author": "Geekles007",
  "homepage": "https://github.com/Geekles007/mdkit#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Geekles007/mdkit.git",
    "directory": "packages/core"
  },
  "bugs": "https://github.com/Geekles007/mdkit/issues",
  "keywords": ["mdx", "markdown", "registry", "schema", "shadcn"],
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "files": ["dist", "README.md"],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "tsup": "^8.3.5",
    "typescript": "^5.6.3",
    "vitest": "^2.1.8"
  }
}
